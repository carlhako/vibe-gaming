DEEPSEEK_API_KEY=

# Shared secret required to view /admin/stats (access log + usage stats).
# Pass it as ?token=... or an `Authorization: Bearer ...` header. Pick
# something long and random - there is no username, just this token.
ADMIN_TOKEN=

# Cost per 1,000,000 DeepSeek API tokens, in USD - used only to display an
# estimated $ cost next to token counts on the /admin/stats history tab.
# Dummy placeholder values below; replace with DeepSeek's real published
# per-model pricing before trusting the displayed costs.
DEEPSEEK_INPUT_COST_PER_MILLION=1.00
DEEPSEEK_OUTPUT_COST_PER_MILLION=2.00

# Optional: LangSmith tracing (smith.langchain.com). Leave LANGSMITH_TRACING
# unset/false to disable entirely - generation works the same either way.
# When enabled, every generation/enhancement job uploads a trace (full
# prompts, generated HTML, token usage, per-attempt retry tree) to
# LangSmith's cloud - remember web visitors' prompts leave the box.
#LANGSMITH_TRACING=true
#LANGSMITH_API_KEY=
#LANGSMITH_PROJECT=vibegames
